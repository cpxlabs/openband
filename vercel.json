{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run lint && npm run test && npm run test:legacy && npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
