{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "expo export -p web && node scripts/post-export.js",
  "outputDirectory": "dist",
  "devCommand": "expo",
  "cleanUrls": true,
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/:path*", "destination": "/" }]
}
