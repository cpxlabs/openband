{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "expo",
  "buildCommand": "npm run lint && npm run test && npm run test:legacy && npm run build",
  "cleanUrls": true,
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=4096"
    }
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
