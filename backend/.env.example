# Backend Environment Variables
# Copy this file to .env and fill in values for production.
#
# Development defaults:
# DATABASE_MODE=sqlite (uses local SQLite — no external services needed)
# All other vars have safe dev defaults.

# ─── Database ──────────────────────────────────────────────────────────────
# Set to "supabase" to use Supabase instead of SQLite.
DATABASE_MODE=sqlite

# SQLite database file path (relative to backend/).
# Default: data/openband.sqlite
SQLITE_DB_PATH=data/openband.sqlite

# ─── Supabase (only used when DATABASE_MODE=supabase) ──────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Also accepts frontend vars as fallback:
# EXPO_PUBLIC_SUPABASE_URL=...
# EXPO_PUBLIC_SUPABASE_ANON_KEY=...

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-dev
GOOGLE_CLIENT_ID=your-google-client-id

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
