# Environment Variables
# Copy this file to .env and fill in your Supabase project credentials.
# See docs/supabase.md for a complete setup guide.
#
# Development without .env:
# When this file is missing or vars are empty, the app auto-falls back
# to a mock auth client — no Supabase account needed.

EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima-aqui
