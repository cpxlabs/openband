{
  "name": "openband-desktop",
  "version": "1.0.0",
  "description": "OpenBand - Desktop music production app",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:electron": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.openband.desktop",
    "productName": "OpenBand",
    "directories": {
      "output": "out"
    },
    "files": [
      "main.js",
      "preload.js",
      "../dist/**/*",
      "../assets/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets",
      "category": "AudioVideo"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.music"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
