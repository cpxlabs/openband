  "scripts": {
    "lint": "npx tsc --noEmit",
    "test": "npx vitest run",
    "test:legacy": "npx tsx --test tests/presets.test.ts tests/types.test.ts",
    "test:ui": "npx vitest --ui",
    "test:ui:screenshot": "node scripts/screenshot-vitest-ui.mjs",
    "build": "expo export --platform web --clear && node scripts/post-export.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "desktop": "npm run build && cd electron && npm start",
    "desktop:dev": "concurrently \"expo start --web\" \"sleep 5 && cd electron && npm start\""
  },
  "private": true
